# UniFi MAC Filtering
# Copy to .env and edit before starting.

APP_NAME="UniFi MAC Filtering"
APP_USERNAME=admin
APP_PASSWORD_HASH=replace_with_output_from_scripts_make_password_hash
APP_SECRET_KEY=replace_with_output_from_openssl_rand_hex_32
SESSION_MINUTES=60
DASHBOARD_TIMEZONE=Asia/Karachi

# Legacy self-hosted UniFi Network Application
UNIFI_BASE_URL=https://127.0.0.1:8443
UNIFI_SITE=default
UNIFI_USERNAME=replace_with_local_unifi_service_admin
UNIFI_PASSWORD='replace_with_local_unifi_service_password'
UNIFI_VERIFY_SSL=false

# Dashboard users
# APP_USERNAME and APP_PASSWORD_HASH bootstrap the first admin user only.
# Create individual support accounts from the Users page after login.

# Server
HOST=0.0.0.0
PORT=4000
DATA_DIR=/opt/mac-filtering/instance

# Safety toggles
ALLOW_ENABLE_FILTERING=true
ALLOW_DISABLE_FILTERING=false
ALLOW_DENY_MODE_EDITS=false
ALLOW_REMOVE_LAST_MAC=false
