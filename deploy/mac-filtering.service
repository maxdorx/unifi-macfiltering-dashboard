[Unit]
Description=mac-filtering dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=unifi-mac-filter
Group=unifi-mac-filter
WorkingDirectory=/opt/mac-filtering
EnvironmentFile=/opt/mac-filtering/.env
ExecStart=/opt/mac-filtering/.venv/bin/python /opt/mac-filtering/run.py
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/mac-filtering/instance

[Install]
WantedBy=multi-user.target
